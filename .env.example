# Multiple Sender Configuration
# Separate emails and passwords with commas (no spaces)
SENDER_EMAILS=email1@gmail.com,email2@gmail.com
SENDER_PASSWORDS=password1,password2

# SMTP Configuration (Port 465 for SSL)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465

# IMAP Configuration (For bounce/reply detection)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
